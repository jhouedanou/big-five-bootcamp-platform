// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user") // "user" | "admin"
  subscriptionStatus String @default("active") // "active" | "inactive" | "expired"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  favorites     SavedCreative[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  plan            String    // "free" | "premium"
  status          String    @default("active")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  stripeCustomerId   String?
  stripeSubscriptionId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Renamed from Content to Creative
model Creative {
  id          String   @id @default(cuid())
  title       String
  thumbnail   String   // URL de l'image/miniature
  videoUrl    String?  // URL de la vidéo (optionnel)
  
  // Classification principale
  platform    String   // "Facebook" | "LinkedIn"
  format      String   // "Image unique", "Carrousel", "Vidéo courte", etc.
  sector      String   // "E-commerce", "Finance", etc.
  objective   String   // "Notoriété", "Trafic", etc.
  
  // Analyse & Détails
  whyItWorks  String?  @db.Text // Pourquoi ça marche
  howToUse    String?  @db.Text // Comment réutiliser
  
  // Meta
  status      String   @default("published") // "draft" | "published"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  favorites   SavedCreative[]
}

model SavedCreative {
  id        String   @id @default(cuid())
  userId    String
  creativeId String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  creative  Creative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@unique([userId, creativeId])
}

// Modèle pour les filtres (optionnel, peut être en dur dans le code)
model SearchFilter {
  id       String @id @default(cuid())
  type     String //Key
  value    String
  label    String
  order    Int    @default(0)
  isActive Boolean @default(true)
}
