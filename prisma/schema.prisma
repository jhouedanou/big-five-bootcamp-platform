// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user") // "user" | "admin" | "moderator"
  plan          String    @default("free") // "free" | "premium" | "enterprise"
  status        String    @default("active") // "active" | "inactive" | "suspended"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  favorites     Favorite[]
  contentViews  ContentView[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  plan            String    // "free" | "premium" | "enterprise"
  status          String    @default("active") // "active" | "cancelled" | "expired"
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  stripeCustomerId   String?
  stripeSubscriptionId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Content {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  videoUrl    String?
  
  // Taxonomie
  brand       String?  // Marque
  advertiser  String?  // Annonceur
  agency      String?  // Agence
  productionCompany String? // Société de production
  
  // Classification
  country     String
  sector      String   // Secteur d'activité
  platform    String   // Plateforme
  format      String   // Format de contenu
  media       String?  // Type de média
  
  // Métadonnées
  year        Int?
  award       String?  // Award reçu
  contributors String? // Contributeurs/personnes
  keywords    String?  // Mots-clés séparés par virgule
  
  // Statut
  status      String   @default("draft") // "draft" | "pending" | "published"
  featured    Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?
  
  tags        ContentTag[]
  favorites   Favorite[]
  views       ContentView[]
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  slug     String       @unique
  color    String?
  contents ContentTag[]
}

model ContentTag {
  contentId String
  tagId     String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model ContentView {
  id        String   @id @default(cuid())
  userId    String?
  contentId String
  viewedAt  DateTime @default(now())
  duration  Int?     // Durée de visionnage en secondes
  
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

// Modèle pour les filtres de recherche
model SearchFilter {
  id       String @id @default(cuid())
  type     String // "country" | "sector" | "platform" | "format" | "media" | "award"
  value    String
  label    String
  icon     String?
  order    Int    @default(0)
  isActive Boolean @default(true)
}
